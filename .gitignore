/.idea/

# Additional local IDE and build output folders to ignore
.kotlin/
.run/
/.vscode/

# Android App build outputs (redundant but explicit)
# Already excluded by **/build/, but keep explicit entry
/app/build/
/app/release/

# Local SDK / Credentials files
/local.properties
/key

/.gradle-user-home/
.Cleanup-Now.ps1
.Dump-Repo.ps1
./tools
/.cursor
/.continue
/build