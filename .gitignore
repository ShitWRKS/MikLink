# Cartelle e file specifici del progetto Android Studio
.gradle
/local.properties
/.idea/workspace.xml
/.idea/libraries/
.DS_Store

/build
# Ignore all build/ folders recursively
**/build/
/captures
/out

# Log KSP e di compilazione
/kspCaches/

# File personali e cache
*.iml
*.class
*.jar

# Files generati dal Debug
